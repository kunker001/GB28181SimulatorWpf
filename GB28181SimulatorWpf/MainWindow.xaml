<Window x:Class="GB28181SimulatorWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:GB28181SimulatorWpf"
        xmlns:conv="clr-namespace:GB28181SimulatorWpf.Converters"
        xmlns:models="clr-namespace:GB28181SimulatorWpf.Models"
        Title="GB28181 设备模拟器 — EasyGBD WPF"
        Height="760" Width="1200"
        MinHeight="640" MinWidth="1000"
        Background="#0B1120"
        Foreground="#F1F5F9"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Converters -->
        <conv:StateToColorConverter    x:Key="StateColor"/>
        <conv:LogLevelToColorConverter x:Key="LogColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <!-- Color palette -->
        <SolidColorBrush x:Key="BgMain"    Color="#0B1120"/>
        <SolidColorBrush x:Key="BgCard"    Color="#161D2E"/>
        <SolidColorBrush x:Key="BgDeep"    Color="#0D1527"/>
        <SolidColorBrush x:Key="BorderCol" Color="#1E2D45"/>
        <SolidColorBrush x:Key="Accent"    Color="#38BDF8"/>
        <SolidColorBrush x:Key="TextMain"  Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextSec"   Color="#64748B"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="RedBrush"  Color="#EF4444"/>

        <!-- Base Button -->
        <Style TargetType="Button">
            <Setter Property="Background"  Value="#0284C7"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"     Value="14,7"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#38BDF8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#1E2D45"/>
                                <Setter Property="Foreground" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EF4444"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#1E2D45"/>
                                <Setter Property="Foreground" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1E2D45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                BorderBrush="#334155" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#243450"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"    Value="#0D1527"/>
            <Setter Property="Foreground"    Value="#F1F5F9"/>
            <Setter Property="BorderBrush"   Value="#1E2D45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"       Value="7,5"/>
            <Setter Property="CaretBrush"    Value="#38BDF8"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#38BDF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"   Value="#0D1527"/>
            <Setter Property="Foreground"   Value="#F1F5F9"/>
            <Setter Property="BorderBrush"  Value="#1E2D45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="7,5"/>
            <Setter Property="FontSize"     Value="13"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"     Color="#0D1527"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#F1F5F9"/>
            </Style.Resources>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0D1527"/>
            <Setter Property="Foreground" Value="#F1F5F9"/>
            <Setter Property="Padding"    Value="7,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E2D45"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0284C7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Card border style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"       Value="#161D2E"/>
            <Setter Property="BorderBrush"      Value="#1E2D45"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="CornerRadius"     Value="8"/>
            <Setter Property="Padding"          Value="14"/>
            <Setter Property="Margin"           Value="0,0,0,10"/>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#64748B"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"            Value="#0D1527"/>
            <Setter Property="Foreground"            Value="#CBD5E1"/>
            <Setter Property="BorderBrush"           Value="#1E2D45"/>
            <Setter Property="BorderThickness"       Value="1"/>
            <Setter Property="RowBackground"         Value="#0D1527"/>
            <Setter Property="AlternatingRowBackground" Value="#111827"/>
            <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E2D45"/>
            <Setter Property="CanUserAddRows"        Value="False"/>
            <Setter Property="CanUserDeleteRows"     Value="False"/>
            <Setter Property="IsReadOnly"            Value="True"/>
            <Setter Property="SelectionMode"         Value="Single"/>
            <Setter Property="HeadersVisibility"     Value="Column"/>
            <Setter Property="FontFamily"            Value="Consolas, Segoe UI"/>
            <Setter Property="FontSize"              Value="12"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"    Value="#1E2D45"/>
            <Setter Property="Foreground"    Value="#94A3B8"/>
            <Setter Property="FontWeight"    Value="SemiBold"/>
            <Setter Property="Padding"       Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E3A5F"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#162032"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#F1F5F9"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"        Value="0"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground"      Value="#64748B"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground"  Value="#38BDF8"/>
                                <Setter Property="BorderBrush" Value="#38BDF8"/>
                                <Setter Property="Background"  Value="#161D2E"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#161D2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- Title Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Main Content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- HEADER                                                       -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="8"
                            Background="#0284C7" Margin="0,0,12,0">
                        <TextBlock Text="GB" FontWeight="Bold" FontSize="13"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="GB28181 设备模拟器" FontSize="16" FontWeight="Bold"
                                   Foreground="#F1F5F9"/>
                        <TextBlock Text="EasyGBD · 批量虚拟设备注册 &amp; 推流" FontSize="11"
                                   Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status summary -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0">
                    <Border Background="#0D1527" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="总设备数：" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTotalDevices" Text="0" Foreground="#38BDF8"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0D1527" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="DotOnline" Width="8" Height="8"
                                     Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="已注册：" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtOnlineCount" Text="0" Foreground="#10B981"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0D1527" CornerRadius="6" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="推流通道：" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtStreamingCount" Text="0" Foreground="#F59E0B"
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Global run status -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="RunStatusDot" Width="10" Height="10"
                             Fill="#475569" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtRunStatus" Text="未运行"
                               Foreground="#64748B" FontSize="13" VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT (Left sidebar + Right panel)                   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────── LEFT SIDEBAR ────────────────────── -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                <!-- SERVER CONFIG CARD -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="SIP 服务器配置" Foreground="#F1F5F9"
                                   FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="服务器 SIP ID" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="TxtServerSipID" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="服务器 IP" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtServerIP"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="SIP 端口" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtServerPort"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="域 ID" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtDomainID"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="注册密码" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtAccessPwd"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- DEVICE CONFIG CARD -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="设备 &amp; 模拟配置" Foreground="#F1F5F9"
                                   FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                        <TextBlock Text="设备起始 SIP ID（后5位自动递增）" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="TxtDeviceSipID" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="模拟设备数量" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtDeviceNum"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="每设备通道数" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtChannelsPerDevice"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="本地 SIP 起始端口" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtDeviceLocalPort"
                                         ToolTip="设备的本地监听端口，多设备自动递增。&#10;必须与服务器端口不同！&#10;示例：WVP 占用 5060，则这里填 5064"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <Border Background="#1A2E1A" CornerRadius="4" Padding="8,6">
                                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#4ADE80">
                                        <Run Text="⚠ 避免与 WVP"/><LineBreak/>
                                        <Run Text="占用的 5060 冲突"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="注册周期 (s)" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtRegPeriod"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="心跳周期 (s)" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtHbPeriod"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="最大心跳丢失" Style="{StaticResource SectionLabel}"/>
                                <TextBox x:Name="TxtMaxHb"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="SIP 协议" Style="{StaticResource SectionLabel}"/>
                                <ComboBox x:Name="ComboProtocol" SelectedIndex="1">
                                    <ComboBoxItem Content="TCP"/>
                                    <ComboBoxItem Content="UDP"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="媒体文件路径 / RTSP URL" Style="{StaticResource SectionLabel}"/>
                        <TextBox x:Name="TxtMediaSource" ToolTip="支持 RTSP URL 或本地 mp4/h264 文件路径"/>
                    </StackPanel>
                </Border>

                <!-- ACTION BUTTONS -->
                <Border Style="{StaticResource Card}" Padding="14,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="BtnStart" Content="▶  启动模拟" Height="36"
                                    Click="BtnStart_Click"/>
                            <Button x:Name="BtnStop" Grid.Column="2" Content="■  停止模拟"
                                    Height="36" Style="{StaticResource DangerBtn}"
                                    IsEnabled="False" Click="BtnStop_Click"/>
                        </Grid>
                        <Button x:Name="BtnSaveConfig" Content="💾  保存配置"
                                Style="{StaticResource GhostBtn}" Height="32"
                                Click="BtnSaveConfig_Click"/>
                    </StackPanel>
                </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- SPLITTER -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="Transparent" ResizeBehavior="PreviousAndNext"/>

            <!-- ─────────────────── RIGHT PANEL ────────────────────── -->
            <TabControl Grid.Column="2">

                <!-- TAB 1: Device Status -->
                <TabItem Header="📡  设备状态">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="实时设备注册状态（每台设备独立显示）"
                                       Foreground="#64748B" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="BtnClearDevices" Grid.Column="1"
                                    Content="清除列表" Style="{StaticResource GhostBtn}"
                                    Padding="10,5" Click="BtnClearDevices_Click"/>
                        </Grid>

                        <!-- Device DataGrid -->
                        <DataGrid x:Name="GridDevices" Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  VerticalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  ScrollViewer.IsDeferredScrollingEnabled="True"
                                  EnableRowVirtualization="True">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"   Value="#1E2D45"/>
                                    <Setter Property="Foreground"   Value="#94A3B8"/>
                                    <Setter Property="FontWeight"   Value="SemiBold"/>
                                    <Setter Property="Padding"      Value="10,7"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontSize"     Value="12"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <!-- Status dot -->
                                <DataGridTemplateColumn Header="" Width="30">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="8" Height="8"
                                                     Fill="{Binding State, Converter={StaticResource StateColor}}"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                                     Margin="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="设备 SIP ID"
                                                    Binding="{Binding DeviceID}" Width="200"
                                                    Foreground="#38BDF8"/>
                                <DataGridTextColumn Header="服务器 ID"
                                                    Binding="{Binding ServerID}" Width="180"
                                                    Foreground="#94A3B8"/>
                                <DataGridTextColumn Header="注册状态"
                                                    Binding="{Binding StateLabel}" Width="120"/>
                                <DataGridTextColumn Header="通道数"
                                                    Binding="{Binding ChannelCount}" Width="70"/>
                                <DataGridTextColumn Header="推流中"
                                                    Binding="{Binding StreamingChannels}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- TAB 2: Log -->
                <TabItem Header="📋  运行日志">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Log Toolbar -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ChkPauseLog" Content="暂停滚动"
                                      Foreground="#94A3B8" VerticalAlignment="Center"
                                      Margin="0,0,16,0"/>
                            <TextBox x:Name="TxtLogFilter" Grid.Column="1"
                                     ToolTip="过滤设备ID或消息内容"
                                     TextChanged="TxtLogFilter_TextChanged"
                                     Margin="0,0,8,0"/>
                            <Button x:Name="BtnClearFilter" Grid.Column="2"
                                    Content="清除" Style="{StaticResource GhostBtn}"
                                    Padding="10,5" Click="BtnClearFilter_Click" Margin="0,0,8,0"/>
                            <Button x:Name="BtnClearLogs" Grid.Column="3"
                                    Content="清空日志" Style="{StaticResource DangerBtn}"
                                    Padding="10,5" Click="BtnClearLogs_Click"/>
                        </Grid>

                        <!-- Log DataGrid -->
                        <DataGrid x:Name="GridLogs" Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  FontFamily="Consolas"
                                  VerticalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  ScrollViewer.IsDeferredScrollingEnabled="True"
                                  EnableRowVirtualization="True">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background"   Value="#1E2D45"/>
                                    <Setter Property="Foreground"   Value="#94A3B8"/>
                                    <Setter Property="FontWeight"   Value="SemiBold"/>
                                    <Setter Property="Padding"      Value="10,7"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontSize"     Value="12"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding Timestamp}"
                                                    Width="100" Foreground="#64748B"/>
                                <DataGridTemplateColumn Header="级别" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Level}"
                                                       Foreground="{Binding Level, Converter={StaticResource LogColor}}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center" Margin="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="设备 ID" Binding="{Binding DeviceID}"
                                                    Width="180" Foreground="#38BDF8"/>
                                <DataGridTextColumn Header="消息" Binding="{Binding Message}"
                                                    Width="*" Foreground="#CBD5E1"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- TAB 3: About -->
                <TabItem Header="ℹ  关于">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <StackPanel Margin="20">
                            <TextBlock Text="GB28181 设备模拟器 WPF" FontSize="22" FontWeight="Bold"
                                       Foreground="#38BDF8" Margin="0,0,0,6"/>
                            <TextBlock Text="基于 EasyGBD (libEasyGBD.dll) · .NET 8.0 WPF · P/Invoke"
                                       Foreground="#64748B" FontSize="13" Margin="0,0,0,20"/>

                            <Border Background="#161D2E" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="功能说明" Foreground="#94A3B8"
                                               FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#CBD5E1" LineHeight="22" FontSize="13">
                                        <Run>• 支持批量模拟 GB28181 标准设备向 SIP 服务器注册</Run><LineBreak/>
                                        <Run>• 设备 ID 自动从起始 ID 递增，每台设备独立 SIP 端口</Run><LineBreak/>
                                        <Run>• 实时显示注册状态：连接中 / 注册中 / 已注册 / 超时 / 认证失败</Run><LineBreak/>
                                        <Run>• 运行日志实时追加，支持设备过滤</Run><LineBreak/>
                                        <Run>• 配置自动保存到 gb28181_sim_config.json</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Background="#161D2E" CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="技术架构" Foreground="#94A3B8"
                                               FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#CBD5E1" LineHeight="22" FontSize="13">
                                        <Run>• P/Invoke 直接调用 libEasyGBD.dll (x64 __stdcall)</Run><LineBreak/>
                                        <Run>• 每设备独立 GB28181ClientCallback 委托（GCHandle 固定）</Run><LineBreak/>
                                        <Run>• 回调事件通过 ConcurrentQueue 安全传递到 UI 线程</Run><LineBreak/>
                                        <Run>• DispatcherTimer 100ms 刷新设备状态与日志</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
